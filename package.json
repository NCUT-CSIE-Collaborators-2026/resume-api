    "dotenv": "^16.6.1",
    "hono": "^4.9.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}