# Runtime server port
PORT=8787

# API route prefix
API_BASE_PATH=/api/resume

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:4200,https://haolun-wang.pages.dev

# External JSON source path (managed in resume-db project)
DATA_FILE_PATH=../resume-db/source/content.i18n.json

# Local SQLite path (runtime source of truth)
DB_PATH=../resume-db/data/resume.db

# If true, import JSON into DB when table is empty
AUTO_MIGRATE_JSON_TO_DB=true
